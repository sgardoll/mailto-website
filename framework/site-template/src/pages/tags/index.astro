---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const entries = await getCollection('entries');
const threads = await getCollection('threads');
const tagCounts = new Map<string, number>();
for (const e of entries) for (const t of e.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
for (const t of threads) for (const tag of t.data.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---
<Base title="Tags">
  <h1>Tags</h1>
  {tags.length === 0 && <p class="meta">No tags yet.</p>}
  <ul class="tag-list">
    {tags.map(([t, n]) => (
      <li><a href={`/tags/${t}`}>#{t} <span class="meta">({n})</span></a></li>
    ))}
  </ul>
</Base>
