---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  const threads = await getCollection('threads');
  const tags = new Set<string>();
  for (const e of entries) for (const t of e.data.tags) tags.add(t);
  for (const t of threads) for (const tag of t.data.tags) tags.add(tag);
  return [...tags].map(tag => ({
    params: { tag },
    props: {
      tag,
      entries: entries.filter(e => e.data.tags.includes(tag)),
      threads: threads.filter(t => t.data.tags.includes(tag)),
    },
  }));
}
const { tag, entries, threads } = Astro.props as {
  tag: string;
  entries: Awaited<ReturnType<typeof getCollection<'entries'>>>;
  threads: Awaited<ReturnType<typeof getCollection<'threads'>>>;
};
---
<Base title={`#${tag}`}>
  <h1>#{tag}</h1>
  {threads.length > 0 && <h2>Threads</h2>}
  {threads.map(t => (
    <article class="thread-card">
      <h3><a href={`/threads/${t.slug}`}>{t.data.title}</a></h3>
      <p>{t.data.summary}</p>
    </article>
  ))}
  {entries.length > 0 && <h2>Entries</h2>}
  {entries.map(e => (
    <article class="entry-card">
      <h3><a href={`/entries/${e.slug}`}>{e.data.title}</a></h3>
      <p>{e.data.summary}</p>
    </article>
  ))}
</Base>
