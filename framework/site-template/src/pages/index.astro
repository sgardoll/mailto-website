---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const threads = (await getCollection('threads'))
  .sort((a, b) => +new Date(b.data.updatedAt) - +new Date(a.data.updatedAt));
const entries = (await getCollection('entries'))
  .sort((a, b) => +new Date(b.data.receivedAt) - +new Date(a.data.receivedAt))
  .slice(0, 10);
const activeThreads = threads.filter(t => t.data.status === 'active');
---
<Base title="Home" description="A growing site, fed by email.">
  <h1>What this is</h1>
  <p>
    This site grows from emails. Each new message is folded into the
    existing threads below — never siloed. Read the
    <a href="/topic">topic</a> for the working theme.
  </p>

  <h2>Active threads</h2>
  {activeThreads.length === 0 && <p class="meta">No threads yet. Send an email.</p>}
  {activeThreads.map(t => (
    <article class="thread-card">
      <h3><a href={`/threads/${t.slug}`}>{t.data.title}</a></h3>
      <p>{t.data.summary}</p>
      <p class="meta">Updated {new Date(t.data.updatedAt).toLocaleDateString()}</p>
    </article>
  ))}

  <h2>Recent entries</h2>
  {entries.map(e => (
    <article class="entry-card">
      <h3><a href={`/entries/${e.slug}`}>{e.data.title}</a></h3>
      <p>{e.data.summary}</p>
      <p class="meta">{new Date(e.data.receivedAt).toLocaleDateString()}</p>
    </article>
  ))}
</Base>
