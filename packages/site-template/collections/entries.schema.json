{
  "$ref": "#/definitions/entries",
  "definitions": {
    "entries": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 400
        },
        "receivedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "source": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "format": "email"
            },
            "subject": {
              "type": "string"
            },
            "messageId": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "threads": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "collection"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "slug": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  }
                },
                "required": [
                  "slug",
                  "collection"
                ],
                "additionalProperties": false
              }
            ]
          },
          "minItems": 1,
          "errorMessage": {
            "minItems": "every entry must belong to at least one thread (fold in, do not silo)"
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "summary",
        "receivedAt",
        "threads"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}