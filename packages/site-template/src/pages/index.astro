---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const spaUrl = `${base}/spa/shell.html`;
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${spaUrl}`} />
    <script define:vars={{ spaUrl }}>window.location.replace(spaUrl);</script>
  </head>
  <body><a href={spaUrl}>Open site</a></body>
</html>
