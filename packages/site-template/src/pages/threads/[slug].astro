---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const threads = await getCollection('threads');
  return threads.map(t => ({ params: { slug: t.slug }, props: { thread: t } }));
}
const { thread } = Astro.props;
const { Content } = await thread.render();
const allEntries = await getCollection('entries');
const inThread = allEntries
  .filter(e => e.data.threads.some(r => r.slug === thread.slug))
  .sort((a, b) => +new Date(b.data.receivedAt) - +new Date(a.data.receivedAt));
const related = await Promise.all(
  thread.data.relatedThreads.map(r => getEntry('threads', r.slug))
);
const base = import.meta.env.BASE_URL;
---
<Base title={thread.data.title} description={thread.data.summary}>
  <p class="meta">Updated {new Date(thread.data.updatedAt).toLocaleString()} · {thread.data.status}</p>
  <h1>{thread.data.title}</h1>
  <p>{thread.data.summary}</p>
  <Content />

  <h2>Entries in this thread</h2>
  {inThread.length === 0 && <p class="meta">None yet.</p>}
  {inThread.map(e => (
    <article class="entry-card">
      <h3><a href={`${base}entries/${e.slug}`}>{e.data.title}</a></h3>
      <p>{e.data.summary}</p>
      <p class="meta">{new Date(e.data.receivedAt).toLocaleDateString()}</p>
    </article>
  ))}

  {related.filter(Boolean).length > 0 && (
    <>
      <h2>Related threads</h2>
      {related.filter(Boolean).map(r => (
        <article class="thread-card">
          <h3><a href={`${base}threads/${r!.slug}`}>{r!.data.title}</a></h3>
          <p>{r!.data.summary}</p>
        </article>
      ))}
    </>
  )}
</Base>
