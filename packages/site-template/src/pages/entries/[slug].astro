---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  return entries.map(e => ({ params: { slug: e.slug }, props: { entry: e } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={entry.data.title} description={entry.data.summary}>
  <p class="meta">Received {new Date(entry.data.receivedAt).toLocaleString()}</p>
  <h1>{entry.data.title}</h1>
  <p>{entry.data.summary}</p>
  <Content />
  <p class="connections">
    Threads:
    {entry.data.threads.map((t, i) => (
      <>{i > 0 && ', '}<a href={`/threads/${t.slug}`}>{t.slug}</a></>
    ))}
  </p>
  {entry.data.tags.length > 0 && (
    <ul class="tag-list">
      {entry.data.tags.map(tag => <li><a href={`/tags/${tag}`}>{tag}</a></li>)}
    </ul>
  )}
</Base>
